<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

    <!-- TMDB API Keys (Injected from Config.xcconfig) -->
    <key>TMDB_API_KEY</key>
    <string>$(TMDB_API_KEY)</string>

    <key>TMDB_ACCESS_TOKEN</key>
    <string>$(TMDB_ACCESS_TOKEN)</string>

    <key>NSCameraUsageDescription</key>
    <string>App requires Camera permission to take user profile image and upload photos</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>App requires Photo Library permission to upload user profile image and upload photos</string>

</dict>
</plist>
